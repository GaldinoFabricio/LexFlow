{
  "name": "@lex-flow/api",
  "version": "0.0.1",
  "private": true,
  "description": "Internal backend API for Lex Flow Assistant",
  "main": "./dist/main.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/main.ts",
    "build": "tsc --project tsconfig.json",
    "start": "node dist/main.js",
    "clean": "rm -rf dist",
    "typecheck": "tsc --project tsconfig.json --noEmit"
  },
  "dependencies": {
    "express": "^4.19.2",
    "@lex-flow/core": "workspace:*",
    "@lex-flow/database": "workspace:*",
    "@lex-flow/auth": "workspace:*",
    "jsonwebtoken": "^9.0.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.12.7",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5",
    "@types/jsonwebtoken": "^9.0.6"
  }
}