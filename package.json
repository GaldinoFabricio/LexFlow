{
  "name": "lex-flow-assistant",
  "version": "1.0.0",
  "private": true,
  "description": "Lex Flow Assistant - WhatsApp integration monorepo",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "pnpm -r run build",
    "build:packages": "pnpm --filter './packages/**' run build",
    "build:apps": "pnpm --filter './apps/**' run build",
    "dev": "pnpm -r --parallel run dev",
    "dev:api": "pnpm --filter @lex-flow/api run dev",
    "dev:web": "pnpm --filter @lex-flow/web run dev",
    "clean": "pnpm -r run clean && rm -rf node_modules",
    "typecheck": "pnpm -r run typecheck",
    "lint": "pnpm -r run lint",
    "test": "pnpm -r run test",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\" --ignore-path .gitignore"
  },
  "devDependencies": {
    "typescript": "^5.4.5",
    "prettier": "^3.2.5",
    "@types/node": "^20.12.7"
  },
  "packageManager": "pnpm@9.1.0"
}
